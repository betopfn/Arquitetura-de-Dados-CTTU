		lineageTag: 5c1dca8b-bf8a-4620-bca9-81cb2f580b33
		summarizeBy: sum
		sourceColumn: dia_semana

		annotation SummarizationSetBy = Automatic

	column fim_de_semana
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 7a5ddb11-e455-479e-80c3-297a82b46b7d
		summarizeBy: none
