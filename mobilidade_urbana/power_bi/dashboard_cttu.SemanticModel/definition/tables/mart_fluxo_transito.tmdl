table mart_fluxo_transito
	lineageTag: ee4c5615-4ea2-48dd-99dc-46ddf313972e

	measure 'Total Veiculos' = SUM(mart_fluxo_transito[quantidade])
		formatString: 0
		lineageTag: cde3d1f7-60cf-49dd-9fb1-86a2207755f7

	measure 'Veiculos Alta Velocidade' = ```
			
			CALCULATE(
			    [Total Veiculos],
			    mart_fluxo_transito[faixa_velocidade] IN {"81-90 km/h", "91-100 km/h", "Acima de 100 km/h"} 
			)
			```
		formatString: 0
		lineageTag: 7c5b9b97-27c4-4297-80e6-22e589884f97

	measure 'Pico Horario' = MAXX(VALUES(mart_fluxo_transito[hora]), [Total Veiculos])
		formatString: 0
		lineageTag: 026b370f-357e-47a0-907e-ec69179e0de1

	measure 'Veiculos por Equipamento' = ```
			
			
			CALCULATE(
			
			SUM(mart_fluxo_transito[total_veiculos]),
			
			ALLEXCEPT(mart_fluxo_transito, mart_fluxo_transito[equipamento])
			
			) 
			```
		formatString: 0
		lineageTag: cadd1877-8ca2-42ab-ac94-274fc05ac076

	measure 'Total Veiculos Fim de Semana' = ```
			
			
			CALCULATE(
			
			    [Total Veiculos],
			
			    dim_tempo[fim_de_semana] = TRUE()
			
			) 
			```
		formatString: 0
		lineageTag: 2391d135-65d3-4d20-a4d8-b52eea28975e

	measure 'Total Veiculos Dia Util' =
			
			
			CALCULATE(
			
			    [Total Veiculos],
			
			    dim_tempo[fim_de_semana] = FALSE()
			
			)
		formatString: 0
		lineageTag: bfad0228-4227-444a-bf1b-16db8d342175

	measure '% Alta Velocidade' = ```
			
			
			DIVIDE(
			
			[Veiculos Alta Velocidade],
			
			[Total Veiculos],
			
			0
			
			) 
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: b3b121ca-932f-47d1-a784-58646f6af69e

	measure 'Total Veiculos Mes Anterior' =
			
			
			CALCULATE(
			
			    [Total Veiculos],
			
			    DATEADD(dim_tempo[data], -1, MONTH)
			
			)
		formatString: 0
		lineageTag: 2f1f6682-4931-4d9b-a2e3-c46b68f4e896

	measure 'Variação % MoM' =
			
			
			DIVIDE(
			
			    [Total Veiculos] - [Total Veiculos Mes Anterior],
			
			    [Total Veiculos Mes Anterior],
			
			    0
			
			)
		lineageTag: 8e2c81b3-c224-4920-b648-f518ada09a2a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Media Diaria Veiculos' = ```
			
			AVERAGEX(
			    VALUES(dim_tempo[data]),
			    [Total Veiculos]
			)
			
			
			```
		lineageTag: 230979bc-790d-4da7-a6cd-fe55f637d26c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Veiculos Acima 60kmh' = ```
			
			CALCULATE(
			    [Total Veiculos],
			    mart_fluxo_transito[faixa_velocidade] IN {"61-70 km/h", "71-80 km/h", "81-90 km/h", "91-100 km/h", "Acima de 100 km/h"} 
			)
			```
		formatString: 0
		lineageTag: 53f7140c-7324-44a4-aeb6-d4e19356cff3

	measure 'Meta Tolerancia 60kmh' = [Total Veiculos] * 0.05
		lineageTag: caf01b5c-034d-4049-81d6-ce7631047b0f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

