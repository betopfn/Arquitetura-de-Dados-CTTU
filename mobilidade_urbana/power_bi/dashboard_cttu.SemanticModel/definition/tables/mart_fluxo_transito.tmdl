	column total_veiculos
		dataType: int64
		formatString: 0
		lineageTag: a1338ddc-b46c-4eb3-8496-c3c4c40212e3
		summarizeBy: sum
		sourceColumn: total_veiculos

		annotation SummarizationSetBy = Automatic

	column 'Ordem Faixa Velocidade' =
			
			SWITCH(
			    mart_fluxo_transito[faixa_velocidade],
			    "0-10 km/h", 1,
			    "11-20 km/h", 2,
			    "21-30 km/h", 3,
			    "31-40 km/h", 4,
			    "41-50 km/h", 5,
			    "51-60 km/h", 6,
			    "61-70 km/h", 7,
			    "71-80 km/h", 8,
			    "81-90 km/h", 9,
			    "91-100 km/h", 10,
			    "Acima de 100 km/h", 11,
			    99
			)
		formatString: 0
		lineageTag: 53e56719-3679-4a8a-9d43-37b8550a4c8a
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	partition mart_fluxo_transito = m
