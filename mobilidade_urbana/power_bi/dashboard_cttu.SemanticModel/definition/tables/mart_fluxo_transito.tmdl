	column faixa_velocidade
		dataType: string
		lineageTag: f75641f2-157d-4edb-bace-6c05793c119a
		summarizeBy: none
		sourceColumn: faixa_velocidade

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column quantidade
		dataType: int64
		formatString: 0
		lineageTag: 72995281-a936-49d2-8feb-0e1a14991e46
